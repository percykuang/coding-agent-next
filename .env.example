# Monorepo env entrypoint
#
# - Web app specific variables: apps/web/.env.example
# - Server app specific variables: apps/server/.env.example
# - Docker/Compose focused variables: .env.docker.example
#
# This root file is intentionally limited to variables commonly used for
# local full-stack联调 or docker-compose orchestration.

WEB_PORT=3000
SERVER_PORT=7001

INTERNAL_API_BASE_URL=http://127.0.0.1:7001
NEXT_PUBLIC_API_BASE_PATH=/api
NEXT_PUBLIC_ASSET_ORIGIN=
NEXT_PUBLIC_ENABLE_FIGMA_ROUTE=true

CORS_ORIGIN=http://localhost:3000
ENABLE_FIGMA_ROUTE=true
