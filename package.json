{
  "name": "coding-agent-next",
  "private": true,
  "packageManager": "pnpm@10.18.2",
  "engines": {
    "node": ">=22.12.0",
    "pnpm": ">=10.18.2"
  },
  "scripts": {
    "dev": "turbo dev",
    "dev:web": "turbo dev --filter=@coding-agent/web",
    "dev:server": "turbo dev --filter=@coding-agent/server",
    "build": "turbo build",
    "build:web": "turbo build --filter=@coding-agent/web",
    "build:server": "turbo build --filter=@coding-agent/server",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "turbo typecheck",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "spellcheck": "cspell --dot .",
    "commitlint": "commitlint",
    "check": "pnpm format:check && pnpm lint && pnpm spellcheck && pnpm typecheck",
    "prepare": "husky",
    "docker:build:web": "docker build --target web-runner -t coding-agent-next-web .",
    "docker:build:server": "docker build --target server-runner -t coding-agent-next-server .",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down"
  },
  "lint-staged": {
    "*.{js,mjs,cjs,ts,tsx,mts,cts}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml,css}": [
      "prettier --write"
    ],
    "*.{js,mjs,cjs,ts,tsx,mts,cts,json,md,yml,yaml,css}": [
      "cspell --no-progress"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@eslint/js": "^9.39.4",
    "cspell": "^9.8.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.1.1",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "turbo": "^2.9.6",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2"
  }
}
