# Server runtime env
#
# This file only contains variables consumed by the Express / agent service.
# Web-specific public env lives in: apps/web/.env.example

PORT=7001
CORS_ORIGIN=http://localhost:3000
MOCK_MODE=false

# Figma route switch
# - true: allow Figma direct flow
# - false: disable Figma direct flow and ask users to use screenshots/text instead
ENABLE_FIGMA_ROUTE=true

# Main model provider
# Optional: deepseek | glm | mimo | ollama
MAIN_MODEL_PROVIDER=mimo

# Vision model provider
# Optional: deepseek | glm | mimo | ollama | qwen
# If omitted, the server will infer a provider from other vision-related envs.
VISION_MODEL_PROVIDER=mimo

# DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_VISION_MODEL=

# GLM
GLM_API_KEY=
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
GLM_MODEL=glm-4-flash
GLM_VISION_MODEL=

# Xiaomi MiMo
MIMO_API_KEY=
MIMO_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1
MIMO_MODEL=mimo-v2.5-pro
MIMO_REASONER_MODEL=mimo-v2.5-pro
# Vision model should use a true multimodal model ID.
MIMO_VISION_MODEL=mimo-v2-omni

# Qwen vision
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-vl-max

# Ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_API_KEY=ollama
OLLAMA_MODEL=qwen3.5:9b
OLLAMA_REASONER_MODEL=qwen3.5:9b
OLLAMA_VISION_MODEL=llama3.2-vision

# Figma MCP
FIGMA_MCP_URL=http://127.0.0.1:3845/mcp
# Optional compatibility aliases used by some code paths / future integrations.
FIGMA_MCP_SERVER_URL=
FIGMA_API_KEY=
DEBUG_FIGMA=false

# Alibaba Cloud OSS
ALI_OSS_AK=
ALI_OSS_SK=
ALI_OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
ALI_OSS_BUCKET=
