# Docker image metadata
# - GitHub Actions 会在远程执行 deploy.sh 时注入 IMAGE_NAMESPACE / IMAGE_TAG
# - 手动部署或回滚时也可以直接改这里，或在命令行覆盖
IMAGE_NAMESPACE=registry.example.com/percy
IMAGE_TAG=main-latest
EDGE_NETWORK=edge

# Public beta policy
CORS_ORIGIN=https://coding.percy.ren
ENABLE_FIGMA_ROUTE=false
NEXT_PUBLIC_API_BASE_PATH=/api
NEXT_PUBLIC_ASSET_ORIGIN=
NEXT_PUBLIC_ENABLE_FIGMA_ROUTE=false

# Server runtime
PORT=7001
MOCK_MODE=false

# Main LLM provider
# Optional: deepseek | glm | mimo | ollama
MAIN_MODEL_PROVIDER=mimo

# Vision provider
# Optional: deepseek | glm | mimo | ollama | qwen
VISION_MODEL_PROVIDER=mimo

# DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_VISION_MODEL=

# GLM
GLM_API_KEY=
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
GLM_MODEL=glm-4-flash
GLM_VISION_MODEL=

# Xiaomi MiMo
MIMO_API_KEY=
MIMO_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1
MIMO_MODEL=mimo-v2.5-pro
MIMO_REASONER_MODEL=mimo-v2.5-pro
MIMO_VISION_MODEL=mimo-v2-omni

# Qwen vision
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-vl-max

# Ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_API_KEY=ollama
OLLAMA_MODEL=qwen3.5:9b
OLLAMA_REASONER_MODEL=qwen3.5:9b
OLLAMA_VISION_MODEL=llama3.2-vision

# Figma MCP
FIGMA_MCP_URL=http://127.0.0.1:3845/mcp
FIGMA_MCP_SERVER_URL=
FIGMA_API_KEY=
DEBUG_FIGMA=false

# Alibaba Cloud OSS (optional)
ALI_OSS_AK=
ALI_OSS_SK=
ALI_OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
ALI_OSS_BUCKET=
